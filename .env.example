# ============================================================
# Clinipharma — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
#
# Drift policy: every `process.env.X` read by app/lib/middleware
# must be listed here OR explicitly exempted via
# `# @env-exempt: X — reason`. Verified by
# scripts/claims/check-env-documented.mjs.
# ============================================================

# ─── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://jomdntqlgrupvhrqoyai.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_DB_PASSWORD=your_database_password_here
# Wave 14 — RLS canary forges short-lived (60s) HS256 JWTs signed with
# this secret to call rls_canary_assert(uuid) as an unaffiliated
# authenticated user. Same secret PostgREST uses to validate every API
# call. Rotate together with the JWT secret in the Supabase dashboard.
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here
# @env-exempt: SUPABASE_DB_PASSWORD — required by the Supabase CLI
# (`supabase db push`) and by hosted migrations; app code itself never
# reads it via `process.env`, so the stale-entry check would otherwise
# flag it. Listed here because operators *must* set it to run migrations.

# ─── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Email transacional — Resend (https://resend.com) ────────
# Obtenha sua API key em: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here
# Remetente verificado no Resend (deve usar domínio verificado em produção)
EMAIL_FROM=Clinipharma <noreply@seudominio.com.br>

# ─── Auth / security ─────────────────────────────────────────
# Secret shared between Vercel Cron and every `/api/cron/*` endpoint.
# Generate: `openssl rand -hex 32`. Tier A — auto-rotated every 90d
# when the `secrets.auto_rotate_tier_a` feature flag is ON.
CRON_SECRET=your_cron_secret_hex_here
# Guards the internal /api/metrics endpoint (Prometheus scrape). Tier A.
# Generate: `openssl rand -hex 32`.
METRICS_SECRET=your_metrics_secret_hex_here
# HMAC key for the backup hash-chain ledger (Wave ≥11). Tier A.
# Generate: `openssl rand -hex 32`.
BACKUP_LEDGER_SECRET=your_backup_ledger_secret_hex_here
# AES-256-GCM key for PII at rest (lib/crypto.ts). Tier C — rotating
# naively *destroys all encrypted PII in place*; see
# docs/runbooks/secret-compromise.md §5. Generate: `openssl rand -hex 32`.
ENCRYPTION_KEY=your_64_char_hex_encryption_key_here
# HMAC key used to sign LGPD data-export bundles so the citizen can
# cryptographically prove the bundle they received was not tampered
# with. Minimum 32 chars. Generate: `openssl rand -hex 32`.
LGPD_EXPORT_HMAC_KEY=your_lgpd_export_hmac_key_here
# Pepper the per-request IP hash so the rate-limit DB never stores
# raw IPs (reversible only with this salt + Cloudflare logs). Tier A.
# Generate: `openssl rand -hex 32`.
RATE_LIMIT_IP_SALT=your_rate_limit_ip_salt_here
# Extra origins permitted for CORS/CSRF on top of NEXT_PUBLIC_APP_URL.
# Comma-separated list. Default: empty (only the canonical app URL).
ALLOWED_ORIGINS=
# If `true`, CSP is emitted as `Content-Security-Policy-Report-Only`
# (observe violations without blocking). Flip to `false` once the
# policy has been validated in staging for ≥7 days. Default: false.
CSP_REPORT_ONLY=false
# If `true`, middleware requires the CSRF double-submit cookie on
# state-changing requests. Default: false (Origin check only).
CSRF_ENFORCE_DOUBLE_SUBMIT=false

# ─── Rate limiting — Upstash Redis ───────────────────────────
# When both are set, lib/rate-limit.ts switches from in-memory (single
# instance) to Redis-backed distributed limiting. Required in prod.
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

# ─── Observability — Sentry ──────────────────────────────────
# DSN is public-by-design (it's in the browser bundle); the server
# checks its presence as a feature flag for error reporting.
NEXT_PUBLIC_SENTRY_DSN=https://your_sentry_dsn_here@o0.ingest.sentry.io/0
# Build-time upload of source maps. Required only in CI — leave blank
# locally to skip the upload step. Tier B.
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=your_sentry_project
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here

# ─── Observability — PagerDuty + ops alerting ────────────────
# Events API v2 routing key for the on-call service. Required for
# auto-paging from money-reconcile / backup-freshness / RLS canary.
PAGERDUTY_ROUTING_KEY=your_pagerduty_routing_key_here
# Where cron-generated alerts CC humans when PagerDuty is OFF
# (gated by the `alerts.email_enabled` feature flag).
OPS_ALERT_EMAIL=ops@clinipharma.com.br

# ─── Push notifications — Firebase Cloud Messaging ───────────
# Server (admin SDK) — required for sending push from cron jobs.
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your_firebase_project_id.iam.gserviceaccount.com
# Paste the full PEM with `\n` line endings or wrap in quotes.
FIREBASE_PRIVATE_KEY=your_firebase_private_key_pem_here
# Web SDK — shipped to the browser. All safe to be public.
NEXT_PUBLIC_FIREBASE_API_KEY=your_web_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_firebase_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_firebase_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your_vapid_public_key_here

# ─── Payments — Asaas (https://asaas.com) ────────────────────
# Sandbox URL is the default; flip to https://api.asaas.com/v3 in prod.
ASAAS_API_URL=https://sandbox.asaas.com/api/v3
ASAAS_API_KEY=your_asaas_api_key_here
# HMAC secret Asaas uses to sign webhook payloads.
ASAAS_WEBHOOK_SECRET=your_asaas_webhook_secret_here

# ─── E-signature — Clicksign (https://clicksign.com) ─────────
CLICKSIGN_API_URL=https://sandbox.clicksign.com/api/v1
CLICKSIGN_ACCESS_TOKEN=your_clicksign_access_token_here
CLICKSIGN_WEBHOOK_SECRET=your_clicksign_webhook_secret_here
# Legal representative e-mail used as the default Clicksign signer on
# auto-generated Clinipharma contracts (falls back to EMAIL_FROM).
CLINIPHARMA_REP_EMAIL=juridico@clinipharma.com.br

# ─── Invoices — Nuvem Fiscal (https://nuvemfiscal.com.br) ────
NUVEM_FISCAL_CLIENT_ID=your_nuvem_fiscal_client_id
NUVEM_FISCAL_CLIENT_SECRET=your_nuvem_fiscal_client_secret
# Clinipharma's own CNPJ used as the invoice issuer.
NUVEM_FISCAL_CNPJ=00000000000000

# ─── AI — OpenAI (OCR + document review) ─────────────────────
OPENAI_API_KEY=sk-your_openai_api_key_here

# ─── Anti-bot — Cloudflare Turnstile ─────────────────────────
# Site key lives in the client bundle; here we only keep the secret.
TURNSTILE_SECRET_KEY=your_turnstile_secret_here

# ─── SMS — Zenvia (WhatsApp intentionally OFF at launch) ─────
ZENVIA_API_TOKEN=your_zenvia_api_token_here
# The Zenvia "Starter + Channel 1" plan does NOT let you register a
# custom alphanumeric sender — the `from` parameter MUST match the
# account username (confirmed by Zenvia support ticket, April 2026).
# End-users receive SMS showing this username as the sender; the
# message body still identifies the brand (see SMS.* templates in
# lib/zenvia.ts). To display a true "Clinipharma" alphanumeric
# sender at the operator level, upgrade the Zenvia plan to a tier
# with Messaging API + custom sender registration, then change
# this value to Clinipharma (no code change required).
ZENVIA_SMS_FROM=cabralandre
# WhatsApp kill-switch. Keep 'false' until Meta Business verification
# completes AND a dedicated business number is registered. Flipping to
# 'true' without ZENVIA_WHATSAPP_FROM will emit warn logs on every send.
WHATSAPP_ENABLED=false
# WhatsApp Business number (E.164, no leading '+'). Ignored while
# WHATSAPP_ENABLED=false.
ZENVIA_WHATSAPP_FROM=5511999999999
# Shared secret sent by Zenvia on every webhook delivery via the
# custom header X-Clinipharma-Zenvia-Secret. Registered once per
# subscription at https://app.zenvia.com (Settings → Subscriptions).
# Without this, app/api/notifications/zenvia returns 401 and all
# delivery-status events are silently dropped.
ZENVIA_WEBHOOK_SECRET=replace_with_a_random_48+_char_string

# ─── Vercel API (Wave 15 — Tier A auto-rotation cron) ────────
# Required for /api/cron/rotate-secrets to actually rotate Tier A
# secrets via the Vercel API. Without them the cron falls back to
# alert-only behaviour for Tier A as well as B/C.
#   VERCEL_TOKEN — API token with env-write scope on the project.
#                  Itself a Tier B secret — rotation procedure §3.2.7
#                  in docs/runbooks/secret-compromise.md.
#   VERCEL_PROJECT_ID — `prj_...` from Vercel project settings.
#   VERCEL_TEAM_ID    — `team_...` for team-owned projects (omit for
#                       personal accounts).
VERCEL_TOKEN=your_vercel_token_here
VERCEL_PROJECT_ID=prj_your_project_id_here
VERCEL_TEAM_ID=team_your_team_id_here

# ─── Cron knobs (optional — have sane defaults) ──────────────
# /api/cron/verify-audit-chain — how far back to replay the chain each
# run (hours) and the max rows to scan before bailing out. Defaults
# 48 h / 500k rows; crank up only if you skipped runs and need a catch-up.
AUDIT_CHAIN_VERIFY_LOOKBACK_HOURS=48
AUDIT_CHAIN_VERIFY_MAX_ROWS=500000
# /api/cron/dsar-sla-check — DSAR SLA warning & expiration grace in
# days (LGPD gives 15d; we warn 3d early and expire 30d past deadline).
DSAR_SLA_WARNING_DAYS=3
DSAR_SLA_EXPIRE_GRACE_DAYS=30
# /api/cron/money-reconcile — max divergent rows logged per run (the
# rest are counted but not serialised, to keep logs small).
MONEY_RECONCILE_MAX_SAMPLES=20
# lib/features/index.ts — TTL for the in-process feature-flag cache.
# 0 disables the cache (useful during flag flips in an incident).
FEATURE_FLAG_CACHE_TTL_MS=5000
# /api/cron/synthetic-probe — override the base URL the probe hits.
# Default: NEXT_PUBLIC_APP_URL in dev, Vercel URL in preview, canonical
# domain in production. Only set this to redirect the probe at a
# specific deployment (e.g. for canary validation).
SYNTHETIC_PROBE_BASE_URL=

# ─── Google OAuth (backlog — not wired in MVP) ───────────────
# Left out intentionally; when Google login ships, add the two env
# vars here plus a matching entry in docs/go-live-checklist.md.

# ============================================================
# Exemptions — env vars the app reads but which are NOT supplied
# via this template. Keep this block in sync with code: every
# `# @env-exempt: X — reason` is enforced by check-env-documented.mjs.
# ============================================================

# Script-only fallbacks: scripts/migrate-pii-encryption.ts + lib/rls-canary.ts
# accept un-prefixed SUPABASE_URL / SUPABASE_ANON_KEY to run outside
# Next.js (where NEXT_PUBLIC_* isn't injected). Operators set them
# ad-hoc on the shell; never part of the Vercel env.
# @env-exempt: SUPABASE_URL — script fallback when NEXT_PUBLIC_SUPABASE_URL is unavailable
# @env-exempt: SUPABASE_ANON_KEY — script fallback when NEXT_PUBLIC_SUPABASE_ANON_KEY is unavailable

# Test infrastructure — injected by CI (GitHub Secrets) or local `.env.test`.
# @env-exempt: BASE_URL — playwright/k6 target URL, set by CI workflow
# @env-exempt: STRICT_A11Y — a11y smoke flag, set only in the accessibility CI job
# @env-exempt: STRYKER_DASHBOARD_PROJECT — set by Stryker itself when uploading to the dashboard
# @env-exempt: STRYKER_DASHBOARD_VERSION — set by Stryker itself when uploading to the dashboard
# @env-exempt: E2E_SUPER_ADMIN_EMAIL — Playwright fixture, set via CI secret
# @env-exempt: E2E_SUPER_ADMIN_PASSWORD — Playwright fixture, set via CI secret
# @env-exempt: E2E_CLINIC_ADMIN_EMAIL — Playwright fixture, set via CI secret
# @env-exempt: E2E_CLINIC_ADMIN_PASSWORD — Playwright fixture, set via CI secret
# @env-exempt: E2E_PHARMACY_EMAIL — Playwright fixture, set via CI secret
# @env-exempt: E2E_PHARMACY_PASSWORD — Playwright fixture, set via CI secret
# @env-exempt: E2E_STAGING_CLINIC_ID — staging UUID, set via CI secret
# @env-exempt: E2E_STAGING_PHARMACY_ID — staging UUID, set via CI secret
# @env-exempt: E2E_STAGING_PRODUCT_ID — staging UUID, set via CI secret
