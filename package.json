    "eslint": "^9",
    "eslint-config-next": "15.5.15",
    "husky": "^9.1.7",
    "jsdom": "^24.1.3",
    "lint-staged": "^16.4.0",
    "pg": "^8.20.0",
    "prettier": "^3.8.1",
