    "inngest": "^4.2.1",
    "lucide-react": "^1.7.0",
    "next": "15.5.15",
    "next-themes": "^0.4.6",
    "openai": "^6.34.0",
    "pdf-lib": "^1.17.1",
    "react": "19.1.0",
