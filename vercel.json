{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "regions": ["gru1"],
  "crons": [
    {
      "path": "/api/cron/stale-orders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/purge-revoked-tokens",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/revalidate-pharmacies",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/cron/enforce-retention",
      "schedule": "0 2 1 * *"
    },
    {
      "path": "/api/cron/purge-drafts",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/cron/coupon-expiry-alerts",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/reorder-alerts",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/churn-check",
      "schedule": "30 7 * * *"
    },
    {
      "path": "/api/cron/product-recommendations",
      "schedule": "0 4 * * 1"
    },
    {
      "path": "/api/cron/expire-doc-deadlines",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/purge-server-logs",
      "schedule": "0 3 * * 1"
    },
    {
      "path": "/api/cron/verify-audit-chain",
      "schedule": "45 3 * * *"
    }
  ]
}
